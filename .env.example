# Copy to .env and fill in.

# Session cookie secret. MUST be at least 32 chars in production.
SESSION_SECRET="dev-only-secret-change-me-in-production-pls-32+chars"

# SQLite database file (path relative to project root)
DB_PATH="storage/db.sqlite"

# ---------------- LLM provider selection ----------------
# One of: openai | anthropic | gemini  (default: openai)
LLM_PROVIDER="openai"

# ---- OpenAI ----
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-7"

# ---- Google Gemini ----
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ---------------- Web search ----------------
# When true, the research module uses the active provider's native web-search
# tool, restricted to a trusted biomedical domain allow-list. When false
# (default), it returns labeled placeholders.
ENABLE_WEB_SEARCH="false"

# ---------------- Progressive Web App / Push notifications ----------------
# OneSignal credentials. Both must be set for push notifications to work.
# Create an app at https://app.onesignal.com -> Settings -> Keys & IDs.
# IMPORTANT: ONESIGNAL_REST_API_KEY is server-side only. Never expose it.
ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""

# Public URL used in push payloads (for icons + default click target).
# Example: https://medagent.example.com
APP_PUBLIC_URL=""

# Shared secret protecting /api/cron/reminders. Pick a long random string;
# the cron job must pass it as ?token=... or X-Cron-Token header.
# Generate one with:  php -r "echo bin2hex(random_bytes(32));"
CRON_SECRET=""
